# Database Configuration
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=erp_platform
DB_PORT=5432

# Spring Datasource Configuration (for Docker)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/erp_platform
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_secure_password

# Spring Datasource Configuration (local development)
# Uncomment if running Spring Boot locally without Docker
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/erp_db

# JWT Configuration
JWT_SECRET=your_256_bit_secret_key_here
JWT_EXPIRATION=86400000

# Hibernate/JPA Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Server Configuration
SERVER_PORT=8080
