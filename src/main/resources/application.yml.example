spring:
  application:
    name: spring-erp-platform

  # Configuration de la base de données (isolée sur le port 5433)
  # Note: Use environment variables for actual credentials
  datasource:
    url: ${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5433/erp_db}
    username: ${SPRING_DATASOURCE_USERNAME}
    password: ${SPRING_DATASOURCE_PASSWORD}
    driver-class-name: org.postgresql.Driver

  # Configuration JPA / Hibernate
  jpa:
    hibernate:
      # 'update' crée les tables si elles n'existent pas, idéal pour ce premier lancement
      ddl-auto: ${SPRING_JPA_HIBERNATE_DDL_AUTO:validate}
    show-sql: true # On active les logs SQL pour voir la création des tables
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.PostgreSQLDialect

  # Configuration Flyway (désactivée temporairement pour laisser Hibernate créer les tables)
  flyway:
    enabled: false

server:
  port: ${SERVER_PORT:8080}

# Paramètres personnalisés pour le JWT
app:
  jwt:
    # Clé de 256 bits - Use environment variable: JWT_SECRET
    secret: ${JWT_SECRET}
    # Expiration : 24 heures (in milliseconds)
    expiration: ${JWT_EXPIRATION:86400000}

# Actuator pour monitorer l'état de l'app
management:
  endpoints:
    web:
      exposure:
        include: health,info
